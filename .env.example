# The Agency — Environment Variables
# Copy this to .env and fill in your values

# Required: Anthropic API key for all agent scripts
ANTHROPIC_API_KEY=sk-ant-api03-...

# Required: Add deepagents SDK to Python path
PYTHONPATH=${PYTHONPATH}:./deepagents/libs/deepagents

